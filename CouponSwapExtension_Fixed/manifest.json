{
  "manifest_version": 3,
  "name": "CouponSwap Finder",
  "version": "1.0",
  "description": "Find coupons for Amazon, Flipkart, Fastrack, and more on CouponSwap!",
  "permissions": ["activeTab", "notifications"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}